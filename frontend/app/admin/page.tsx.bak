          {/* в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
              REPORTES
          в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ */}
          {!loading && tab === "reportes" && (
            <div className="grid grid-cols-1 gap-6 md:grid-cols-2">
              <div className="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
                <p className="font-semibold mb-4">Facturas por estado</p>
                <ul className="space-y-2 text-sm">
                  {["PAGADA", "PENDIENTE", "ACTIVA", "ANULADA"].map((e) => (
                    <li key={e} className="flex justify-between border-b pb-2">
                      <span className="text-gray-600">{e}</span>
                      <span className="font-semibold">
                        {facturas.filter((f) => f.FAC_ESTADO_FACTURA === e).length}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>

              <div className="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
                <p className="font-semibold mb-4">Г“rdenes por estado</p>
                <ul className="space-y-2 text-sm">
                  {["ACTIVO", "FINALIZADO", "ANULADO"].map((e) => (
                    <li key={e} className="flex justify-between border-b pb-2">
                      <span className="text-gray-600">{e}</span>
                      <span className="font-semibold">
                        {ordenes.filter((o) => o.ODV_ESTADO === e).length}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>

              <div className="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
                <p className="font-semibold mb-4">Ventas por tienda</p>
                <ul className="space-y-2 text-sm">
                  {tiendas.slice(0, 8).map((t) => {
                    const total = ordenes
                      .filter((o) => o.TIE_TIENDA === t.TIE_TIENDA)
                      .reduce((acc, o) => acc + Number(o.ODV_TOTAL ?? 0), 0);
                    return (
                      <li key={t.TIE_TIENDA} className="flex justify-between border-b pb-2">
                        <span className="text-gray-600">{t.TIE_NOMBRE}</span>
                        <span className="font-semibold">{formatCurrency(total)}</span>
                      </li>
                    );
                  })}
                </ul>
              </div>

              <div className="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
                <p className="font-semibold mb-4">Muebles por categorГ­a</p>
                <ul className="space-y-2 text-sm">
                  {categorias.slice(0, 8).map((c) => {
                    const count = productos.filter(
                      (p) => p.TIP_TIPO_PRODUCTO === c.TIP_TIPO_PRODUCTO,
                    ).length;
                    return (
                      <li key={c.TIP_TIPO_PRODUCTO} className="flex justify-between border-b pb-2">
                        <span className="text-gray-600">{c.TIP_NOMBRE}</span>
                        <span className="font-semibold">{count}</span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            </div>
          )}

        </main>
      </div>
    </div>
  );
}

