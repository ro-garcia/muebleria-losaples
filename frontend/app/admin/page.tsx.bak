                            >
                              Ver detalle
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>

              {clienteDetalle && (
                <div className="grid grid-cols-1 gap-6 lg:grid-cols-2">
                  <SectionCard title="Perfil del cliente" subtitle="Datos de MUE_CLIENTE y cuenta asociada">
                    <div className="space-y-2 text-sm">
                      <p><strong>ID:</strong> {String(clienteDetalle.CLI_CLIENTE ?? "вЂ”")}</p>
                      <p><strong>Nombre:</strong> {String(clienteDetalle.CLI_PRIMER_NOMBRE ?? "")} {String(clienteDetalle.CLI_PRIMER_APELLIDO ?? "")}</p>
                      <p><strong>Correo:</strong> {String(clienteDetalle.CLI_CORREO_ELECTRONICO ?? "вЂ”")}</p>
                      <p><strong>TelГ©fono:</strong> {String(clienteDetalle.CLI_TELEFONO ?? "вЂ”")}</p>
                      <p><strong>Documento:</strong> {String(clienteDetalle.CLI_TIPO_DOCUMENTO ?? "вЂ”")} {String(clienteDetalle.CLI_NUMERO_DOCUMENTO ?? "")}</p>
                      <p><strong>Usuario:</strong> {String(clienteDetalle.USU_NOMBRE_USUARIO ?? "Sin usuario")}</p>
                      <p><strong>ContraseГ±a:</strong> {String(clienteDetalle.USU_PASSWORD_STATUS ?? "No registrada")}</p>
                    </div>
                  </SectionCard>

                  <SectionCard title="Historial de compras" subtitle="Г“rdenes, factura y detalle de productos">
                    <div className="max-h-80 overflow-auto rounded-lg border">
